<UserControl
    x:Class="NugetMVVP.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Border CornerRadius="12">

        <!--  BACKGROUND  -->
        <Border.Background>
            <ImageBrush ImageSource="pack://application:,,,/NugetMVVP;component/Images/back-image.jpg" />
        </Border.Background>

        <Border
            BorderThickness="2"
            CornerRadius="10"
            Opacity="0.95">

            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#462AD8" />
                    <GradientStop Offset="0.75" Color="#DA34AE" />
                    <GradientStop Offset="1" Color="#8A16C1" />
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Border.Background>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Offset="0" Color="#060531" />
                    <GradientStop Offset="1" Color="#1B1448" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>

                <Grid
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Margin="0,0,0,446">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="25" />
                        <ColumnDefinition Width="25" />
                        <ColumnDefinition Width="5" />
                    </Grid.ColumnDefinitions>

                </Grid>

                <!--  CONTENT  -->
                <StackPanel
                    Grid.Row="1"
                    Width="220"
                    Margin="0,35,0,0"
                    HorizontalAlignment="Center">

                    <!--  LOGO  -->
                    <Image
                        Width="100"
                        Height="100"
                        Source="pack://application:,,,/NugetMVVP;component/Images/logo.png" />

                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="25"
                        Foreground="White"
                        Text="JS DEV" />
                    <!--  Username Label  -->
                    <TextBlock
                        Margin="0,35,0,0"
                        Foreground="DarkGray"
                        Text="Username" />

                    <!--  Username Input  -->
                    <Border
                        Margin="0,5,0,0"
                        BorderBrush="Gray"
                        BorderThickness="0,0,0,1">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <Image
                                Width="14"
                                Height="14"
                                Margin="2,-3,2,3"
                                Source="/Images/user-icon.png" />

                            <TextBox
                                Grid.Column="1"
                                Margin="0,-2,0,2"
                                Padding="5,0,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White"
                                Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                    <!--  Password Label  -->
                    <TextBlock
                        Margin="0,15,0,0"
                        Foreground="DarkGray"
                        Text="Password" />

                    <!--  Password Input  -->
                    <Border
                        Margin="0,5,0,0"
                        BorderBrush="Gray"
                        BorderThickness="0,0,0,1">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <Image
                                Width="16"
                                Height="16"
                                Margin="2,-2,2,2"
                                Source="/Images/key-icon.png" />

                            <PasswordBox
                                x:Name="PasswordBox"
                                Grid.Column="1"
                                Margin="0,-2,0,2"
                                Padding="5,0,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White"
                                PasswordChanged="PasswordBox_PasswordChanged" />
                        </Grid>
                    </Border>

                    <!--  LOGIN BUTTON  -->
                    <Button
                        Width="150"
                        Height="40"
                        Margin="0,50,0,0"
                        Background="#462AD8"
                        Command="{Binding LoginCommand}"
                        Content="Login"
                        Foreground="White" />
                </StackPanel>
            </Grid>

        </Border>
    </Border>
</UserControl>