<Window
    x:Class="NugetMVVP.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:NugetMVVP.ViewModels"
    Width="930"
    Height="580"
    Background="Transparent"
    ResizeMode="NoResize"
    WindowStyle="None">

    <Window.DataContext>
        <vm:NavigationViewModel />
    </Window.DataContext>

    <Grid>

        <Border Background="#ECF0F1" CornerRadius="10" />

        <!--  Header top  -->
        <Border
            Width="850"
            Height="80"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="#5C5C5C"
            CornerRadius="10, 0, 100,0">
            <TextBlock Style="{StaticResource HeaderStyle}" Text="W E L C O M E  TO  W I N D O W  A P P L I C A T I O N" />
        </Border>

        <!--  Footer  -->
        <Border
            Width="850"
            Height="80"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Background="#5C5C5C"
            CornerRadius="100,0,10,0">

            <TextBlock Style="{StaticResource FooterStyle}" Text="D E S I G N   T H E   I N T E R F A C E" />
        </Border>

        <!--  Content background  -->
        <Border
            Height="480"
            Margin="0,10,0,0"
            Background="#303030"
            BorderBrush="#ffffff"
            BorderThickness="0,5,0,5"
            CornerRadius="25" />

        <!--  Content Grid  -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="25" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="660" />
                <ColumnDefinition Width="25" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>

                <RowDefinition Height="0" />
                <RowDefinition Height="80" />
                <RowDefinition Height="55" />
                <RowDefinition Height="370" />
                <RowDefinition Height="0" />

            </Grid.RowDefinitions>

            <!--  Menu Search  -->
            <Grid Grid.Row="2" Grid.Column="1">

                <TextBox
                    x:Name="SearchBox"
                    Style="{StaticResource SearchBoxStyle}"
                    Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Style="{StaticResource SearchTextStyle}" Text="Search" />

            </Grid>

            <!--  Menu  -->
            <Grid
                Grid.Row="3"
                Grid.Column="1"
                Margin="0,10,0,0">

                <ItemsControl ItemsSource="{Binding SourceCollection}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <RadioButton
                                    Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ItemsControl}}, Path=DataContext.MenuCommand}"
                                    CommandParameter="{Binding MenuName}"
                                    Content="{Binding MenuName}"
                                    GroupName="MenuGroup"
                                    Style="{StaticResource MenuButtonStyle}"
                                    Tag="{Binding MenuImage}" />

                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Grid>

            <!--  Page Container  -->
            <Grid
                Grid.Row="2"
                Grid.RowSpan="2"
                Grid.Column="3"
                Background="Transparent">

                <ContentControl x:Name="Pages" Content="{Binding SelectedViewModel}" />

            </Grid>
        </Grid>


        <!--  Exit the app  -->
        <Button
            Width="50"
            Height="50"
            Margin="0,5,20,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Command="{Binding ExitCommand}"
            Style="{StaticResource CloseBtn_Style}" />
    </Grid>
</Window>
