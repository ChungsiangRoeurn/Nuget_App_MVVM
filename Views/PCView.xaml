<UserControl
    x:Class="NugetMVVP.Views.PCView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NugetMVVP.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Style>
        <Style>
            <Style.Triggers>
                <EventTrigger RoutedEvent="UserControl.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Opacity"
                                From="0.0"
                                To="1.0"
                                Duration="0:0:0.5" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>
    <Grid Background="#303030">

        <RadioButton
            Width="40"
            Height="40"
            Margin="0,10,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}, Path=DataContext.BackHomeCommand}"
            Style="{StaticResource HomeButtonStyle}"
            Tag="Assets/back_icon.png" />

        <StackPanel
            Margin="5,12,0,0"
            VerticalAlignment="Top"
            Orientation="Horizontal">

            <Button
                Padding="0"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding DataContext.BackHomeCommand, RelativeSource={RelativeSource AncestorType=Window}}">

                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>


                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="24"
                    Foreground="#DDDDDD"
                    Text="Home" />
            </Button>

            <TextBlock
                VerticalAlignment="Center"
                FontSize="24"
                Foreground="#AAAAAA"
                Text="  &gt;  " />

            <TextBlock
                VerticalAlignment="Center"
                FontSize="22"
                Foreground="#DDDDDD"
                Text="This PC" />

        </StackPanel>


        <ItemsControl
            Width="650"
            Height="350"
            Margin="0,40,0,0"
            HorizontalAlignment="Center"
            ItemsSource="{Binding PCSourceCollection}">

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <RadioButton GroupName="PCGroup" Style="{StaticResource GridButtonStyle}">

                        <StackPanel HorizontalAlignment="Center">

                            <Image
                                Width="40"
                                Height="40"
                                Source="{Binding PCImage}" />

                            <TextBlock
                                HorizontalAlignment="Center"
                                Foreground="White"
                                Text="{Binding PCName}" />

                        </StackPanel>

                    </RadioButton>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4" Rows="3" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

        </ItemsControl>
    </Grid>
</UserControl>
